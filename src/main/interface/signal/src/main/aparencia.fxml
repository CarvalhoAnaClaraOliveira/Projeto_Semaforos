<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox style="-fx-background-color: #f0f0f0; -fx-padding: 10;">
            <Label text="Sistema de Controle de Semáforos" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <HBox spacing="10" style="-fx-padding: 10;">
                <Button text="Iniciar Simulação" style="-fx-font-size: 12; -fx-padding: 8;"/>
                <Button text="Parar" style="-fx-font-size: 12; -fx-padding: 8;"/>
                <Button text="Limpar" style="-fx-font-size: 12; -fx-padding: 8;"/>
            </HBox>
        </VBox>
    </top>
    
    <center>
        <Canvas width="800" height="600" style="-fx-background-color: #ffffff; -fx-border-color: #cccccc;"/>
    </center>
    
    <right>
        <VBox style="-fx-background-color: #f9f9f9; -fx-padding: 10; -fx-border-color: #dddddd; -fx-border-width: 1 0 0 1;" spacing="10" minWidth="200">
            <Label text="Estado dos Semáforos" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            
            <VBox style="-fx-border-color: #dddddd; -fx-border-width: 1; -fx-padding: 8;">
                <Label text="Semáforo 1" style="-fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label text="Estado: Verde" style="-fx-text-fill: #00aa00;"/>
                <Label text="Tempo: 30s" style="-fx-font-size: 11;"/>
            </VBox>
            
            <VBox style="-fx-border-color: #dddddd; -fx-border-width: 1; -fx-padding: 8;">
                <Label text="Semáforo 2" style="-fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label text="Estado: Vermelho" style="-fx-text-fill: #cc0000;"/>
                <Label text="Tempo: 45s" style="-fx-font-size: 11;"/>
            </VBox>
            
            <VBox style="-fx-border-color: #dddddd; -fx-border-width: 1; -fx-padding: 8;">
                <Label text="Semáforo 3" style="-fx-font-size: 12; -fx-font-weight: bold;"/>
                <Label text="Estado: Amarelo" style="-fx-text-fill: #ffaa00;"/>
                <Label text="Tempo: 5s" style="-fx-font-size: 11;"/>
            </VBox>
            
            <Label text="Fluxo de Veículos" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 10 0 0 0;"/>
            <Label text="Via 1: 12 carros" style="-fx-font-size: 11;"/>
            <Label text="Via 2: 8 carros" style="-fx-font-size: 11;"/>
            <Label text="Via 3: 15 carros" style="-fx-font-size: 11;"/>
        </VBox>
    </right>
    
    <bottom>
        <HBox style="-fx-background-color: #f0f0f0; -fx-padding: 10; -fx-border-color: #dddddd; -fx-border-width: 1 0 0 0;">
            <Label text="Status: Simulação em execução" style="-fx-font-size: 11;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Tempo Total: 120s" style="-fx-font-size: 11; -fx-text-fill: #0066cc;"/>
        </HBox>
    </bottom>
</BorderPane>
