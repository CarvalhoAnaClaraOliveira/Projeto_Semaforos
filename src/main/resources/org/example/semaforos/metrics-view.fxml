<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.semaforos.DashboardMetricsController">

    <top>
        <VBox spacing="10" styleClass="header">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <Label styleClass="header-title" text="Sistema Inteligente de Gerenciamento de Semaforos" />

            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #34495e; -fx-padding: 10px;">
                <Label fx:id="labelTotalVeiculos" styleClass="label-metric" text="Total de Veiculos: 0" HBox.hgrow="ALWAYS" />
                <Separator orientation="VERTICAL" prefHeight="30" />
                <Label fx:id="labelCruzamentosAtivos" styleClass="label-metric" text="Cruzamentos: 16" HBox.hgrow="ALWAYS" />
                <Separator orientation="VERTICAL" prefHeight="30" />
                <Label fx:id="labelSemaforosStatus" styleClass="label-metric" text="Abertos: 0 | Fechados: 0" HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane styleClass="tab-pane" tabClosingPolicy="UNAVAILABLE">
            <Tab closable="false" text="Informacoes do Sistema">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="20">
                        <padding>
                            <Insets bottom="20" left="20" right="20" top="20" />
                        </padding>

                        <VBox spacing="10" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #ecf0f1;">
                            <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Relatorio de Veiculos" />
                            <Separator />
                            <HBox spacing="30">
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Total de Veiculos" />
                                    <Label fx:id="infoTotalVeiculos" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2980b9;" text="0" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Veiculos em Movimento" />
                                    <Label fx:id="infoVeiculosEmMovimento" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #27ae60;" text="0" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Veiculos em Espera" />
                                    <Label fx:id="infoVeiculosEmEspera" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #f39c12;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="10" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #ecf0f1;">
                            <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Status dos Cruzamentos" />
                            <Separator />
                            <HBox spacing="30">
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Total de Cruzamentos" />
                                    <Label fx:id="infoTotalCruzamentos" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2980b9;" text="16" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Cruzamentos Ativos" />
                                    <Label fx:id="infoCruzamentosAtivos" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #27ae60;" text="0" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Cruzamentos Ociosos" />
                                    <Label fx:id="infoCruzamentosOciosos" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #95a5a6;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox spacing="10" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 15; -fx-background-color: #ecf0f1;">
                            <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Status dos Semaforos" />
                            <Separator />
                            <HBox spacing="30">
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Total de Semaforos" />
                                    <Label fx:id="infoTotalSemaforos" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2980b9;" text="0" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Semaforos Abertos" />
                                    <Label fx:id="infoSemaforosVerde" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #27ae60;" text="0" />
                                </VBox>
                                <VBox spacing="5">
                                    <Label style="-fx-text-fill: #34495e; -fx-font-size: 11px;" text="Semaforos Fechados" />
                                    <Label fx:id="infoSemaforosVermelho" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #e74c3c;" text="0" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <Tab closable="false" text="Dashboard">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="15" styleClass="dashboard-container">
                        <padding>
                            <Insets bottom="20" left="20" right="20" top="20" />
                        </padding>
                        <Label styleClass="label-title" text="Relatorio do Trafego em Tempo Real" />
                        <VBox fx:id="dashboardContainer" spacing="15" />
                    </VBox>
                </ScrollPane>
            </Tab>

            <Tab closable="false" text="Cruzamentos">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="15">
                        <padding>
                            <Insets bottom="20" left="20" right="20" top="20" />
                        </padding>
                        <Label styleClass="label-title" text="Status dos Cruzamentos" />
                        <GridPane fx:id="gridCruzamentos" hgap="15" style="-fx-padding: 15; -fx-background-color: #ecf0f1;" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                                <ColumnConstraints percentWidth="25" />
                            </columnConstraints>
                        </GridPane>
                    </VBox>
                </ScrollPane>
            </Tab>

            <Tab closable="false" text="Ruas">
                <ScrollPane fitToWidth="true">
                    <VBox spacing="15">
                        <padding>
                            <Insets bottom="20" left="20" right="20" top="20" />
                        </padding>
                        <Label styleClass="label-title" text="Monitoramento de Ruas" />
                        <GridPane fx:id="gridRuas" hgap="20" style="-fx-padding: 15; -fx-background-color: #ecf0f1;" vgap="15">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>
                        </GridPane>
                    </VBox>
                </ScrollPane>
            </Tab>
        </TabPane>
    </center>

    <bottom>
        <HBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 10px;">
            <padding>
                <Insets bottom="10" left="20" right="20" top="10" />
            </padding>
            <Label fx:id="labelStatus" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold;" text="Sistema Rodando" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="labelTempo" style="-fx-text-fill: white;" text="Tempo: 0s" />
            <Separator orientation="VERTICAL" />
            <Label fx:id="labelFPS" style="-fx-text-fill: white;" text="FPS: 60" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 10px;" text="v1.0 - Sistema de Gerenciamento de Semaforos Inteligentes" />
        </HBox>
    </bottom>
</BorderPane>
